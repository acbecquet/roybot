<!-- models/roybot.xml : differential-drive robot, 2 wheels + caster -->
<mujoco model="roybot">
  <!-- implicitfast + wheel armature stabilize the low-inertia driven wheel DOF;
       plain Euler at dt=2ms makes the velocity-servo'd wheel explode. -->
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"/>
  <default>
    <!-- low wheel damping so the realistic 0.15 N.m torque limit (not artificial drag)
         is what caps acceleration; armature + implicitfast keep the wheel DOF stable. -->
    <joint damping="0.001" armature="0.001"/>
    <geom friction="1 0.1 0.01"/>
  </default>

  <worldbody>
    <geom name="floor" type="plane" size="5 5 0.1" rgba="0.85 0.9 0.85 1"
          friction="1 0.1 0.01"/>

    <body name="chassis" pos="0 0 0.03">
      <freejoint name="root"/>
      <!-- round 3216 chassis (~109 mm dia). mass ~0.36 kg body (+wheels+caster ~0.42 kg total);
           ESTIMATE - refine from the kitchen-scale weight of the assembled bot. -->
      <geom name="chassis_geom" type="cylinder" size="0.0545 0.015" mass="0.36"
            rgba="0.3 0.45 0.8 1"/>
      <site name="imu" pos="0 0 0" size="0.005"/>

      <body name="left_wheel" pos="0 0.055 0.0">
        <joint name="left_wheel_joint" type="hinge" axis="0 1 0"/>
        <geom type="cylinder" size="0.03 0.008" quat="0.7071 0.7071 0 0"
              mass="0.025" rgba="0.15 0.15 0.15 1" friction="1.2 0.1 0.01"/>
      </body>

      <body name="right_wheel" pos="0 -0.055 0.0">
        <joint name="right_wheel_joint" type="hinge" axis="0 1 0"/>
        <geom type="cylinder" size="0.03 0.008" quat="0.7071 0.7071 0 0"
              mass="0.025" rgba="0.15 0.15 0.15 1" friction="1.2 0.1 0.01"/>
      </body>

      <!-- caster: low-friction ball so the rear slides freely -->
      <body name="caster" pos="0.04 0 -0.018">
        <geom type="sphere" size="0.012" mass="0.005" rgba="0.6 0.6 0.6 1"
              friction="0.05 0.005 0.0001"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- forcerange = real 100:1 N20 stall torque ~0.157 N.m (slightly derated). Encoders let the Pi
         close the wheel-speed loop, so this velocity actuator has a faithful hardware counterpart. -->
    <velocity name="left_motor"  joint="left_wheel_joint"  kv="5.0" forcerange="-0.15 0.15"/>
    <velocity name="right_motor" joint="right_wheel_joint" kv="5.0" forcerange="-0.15 0.15"/>
  </actuator>

  <sensor>
    <framepos    name="chassis_pos"    objtype="site" objname="imu"/>
    <framequat   name="chassis_quat"   objtype="site" objname="imu"/>
    <framelinvel name="chassis_linvel" objtype="site" objname="imu"/>
    <frameangvel name="chassis_angvel" objtype="site" objname="imu"/>
  </sensor>
</mujoco>
